---
import Form from "~/components/Form.astro";
import GoogleMaps from "~/components/GoogleMaps.astro";

const message =
  "Hola! Vengo de la página web, me interesa consultar por más información.";
const whatsAppNumber = "+5493512462389";
const phoneNumber = "+54 9 351 4705050";
const phones = "351 4705050 / 7284662";

const contactItems = [
  {
    icon: "https://img.icons8.com/?size=30&id=62855&format=png&color=1c398e",
    text: whatsAppNumber,
    link: `https://api.whatsapp.com/send?phone=${whatsAppNumber}&text=${message}`,
    alt: "Icono de WhatsApp",
  },
  {
    icon: "https://img.icons8.com/?size=30&id=78382&format=png&color=1c398e",
    text: phones,
    link: `tel:${phoneNumber}`,
    alt: "Icono de teléfono",
  },
  {
    icon: "https://img.icons8.com/?size=30&id=7880&format=png&color=1c398e",
    text: "Juan B Justo 4667 (por colectora)",
    link: "https://maps.app.goo.gl/UJcR8xsEpK1c2Sc3A",
    alt: "Icono de dirección",
  },
  {
    icon: "https://img.icons8.com/?size=30&id=7880&format=png&color=1c398e",
    text: "Parque Industrial Mi Granja - Ruta 19 km 320",
    link: "https://maps.app.goo.gl/VtH1nCYkoJB1m9Qx5",
    alt: "Icono de dirección",
  },
];
---

<section
  class="lg:min-h-[calc(100vh-125px)] flex flex-col md:flex-col lg:flex-row justify-center lg:justify-around items-center gap-6 px-8 md:px-24 py-16 md:py-8 lg:py-0 lg:px-40"
>
  <div
    class="flex flex-col gap-4 w-full lg:w-6/12 md:w-full mb-0 md:mb-6 lg:mb-0"
  >
    <div class="flex flex-col md:items-start lg:items-start justify-between">
      <h1
        class="text-3xl font-bold md:text-4xl text-blue-dark block md:hidden lg:hidden mb-4"
      >
        Datos de contacto
      </h1>
      {
        contactItems.map((item) => (
          <p class="font-medium text-sm md:text-lg lg:text-xl text-blue-dark flex items-center gap-2">
            <img src={item.icon} alt={item.alt} class="w-6" />
            <a class="hover:underline" href={item.link} target="_blank">
              {item.text}
            </a>
          </p>
        ))
      }
    </div>
    <GoogleMaps />
  </div>
  <Form />
</section>
